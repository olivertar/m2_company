<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="customer.new">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">
                    Orangecat_Company::company_link.phtml
                </argument>
            </action>
            <block class="Magento\Customer\Block\Form\Login\Info" name="customer.link.new" template="Orangecat_Company::customer_link.phtml" ifconfig="mycompany/customers/allow_frontend_customer_registration"/>
        </referenceBlock>
    </body>
</page>
