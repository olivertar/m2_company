# Environment Variables for Orangecat_Company E2E Tests
#
# These variables are consumed by the shared test configuration at:
#   dev/tests/playwright/lib/env.ts
#
# Copy this file to dev/tests/playwright/.env and fill in the values,
# or export them in your shell before running tests.

# Magento Frontend & Admin URLs
BASE_URL=https://my-b2b.test
ADMIN_URL=https://my-b2b.test/admin

# Magento Admin credentials
ADMIN_USER=admin
ADMIN_PASS=xxxxxx

# Company accounts for B2B testing
# COMPANY_ADMIN must have Role ID 1 (Company Admin) in the ACME company
COMPANY_ADMIN=admincompany@test.com

# COMPANY_MANAGER must have a non-admin role (e.g. Manager or Buyer)
COMPANY_MANAGER=managercompany@test.com

# Shared password for both company accounts above
COMPANY_PASS=xxxxxx
